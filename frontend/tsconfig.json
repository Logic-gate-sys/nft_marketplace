{
  "include": ["src/"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "module": "ESNext",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "ESNext"],
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // custom imports and alias
    "baseUrl": "./src",
    "paths": {
      "@components/*": ["./components/*"], // Added the 's'
      "@pages/*": ["./pages/*"],
      "@hooks/*": ["./hooks/*"],
      "@context/*": ["./context/*"],
      "@ether-wallet/*": ["./ether/*"],
      "@constants/*":["./constants/*"],
      "@my-types/*":["./services/types.ts"],
      "@utils/*":["./utils/*"]
    }
  }
}
